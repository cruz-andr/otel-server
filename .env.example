# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Jaeger
JAEGER_BASE_URL=http://localhost:16686
JAEGER_TIMEOUT_MS=10000

# Log limits
MAX_LOG_LINES=500
DEFAULT_LOG_LINES=100

# Trace limits
MAX_TRACE_SPANS=200
DEFAULT_LOOKBACK=1h

# PII redaction (set to "false" to disable)
REDACT_PATTERNS=true

# Transport: "stdio" (default) or "http" (Streamable HTTP)
TRANSPORT=stdio
PORT=3000
